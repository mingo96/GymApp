<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#00000000" />
            <stroke
                android:width="2dp"
                android:color="#3327E0A9" />
            <size
                android:width="60dp"
                android:height="60dp" />
        </shape>
    </item>
    <!-- Main bubble -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#F2131318" />
            <stroke
                android:width="1.5dp"
                android:color="#6627E0A9" />
            <size
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/expanded_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content card -->
    <LinearLayout
        android:id="@+id/content_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/expanded_bg"
        android:elevation="8dp"
        android:layout_margin="8dp">

        <!-- Drag handle to move the panel -->
        <FrameLayout
            android:id="@+id/drag_handle"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="@android:color/transparent">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="@drawable/spinner_bg" />

        </FrameLayout>

        <!-- Scrollable content area -->
        <ScrollView
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header with title and minimize button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/txt_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Entrenamiento"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btn_minimize"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/arrow_down_float"
                        android:contentDescription="Minimizar"
                        android:scaleType="centerInside" />

                </LinearLayout>

                <!-- Exercise slider label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ejercicio"
                    android:textColor="#B0B0B0"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <!-- Swipe exercise selector -->
                <FrameLayout
                    android:id="@+id/exercise_swipe"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/exercise_chip_bg">

                    <!-- Left arrow -->
                    <TextView
                        android:id="@+id/exercise_arrow_left"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="‹"
                        android:textColor="#8080AA"
                        android:textSize="22sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="4dp"
                        android:layout_gravity="start|center_vertical" />

                    <!-- Exercise name -->
                    <TextView
                        android:id="@+id/exercise_name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="–"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:paddingStart="32dp"
                        android:paddingEnd="32dp" />

                    <!-- Right arrow -->
                    <TextView
                        android:id="@+id/exercise_arrow_right"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#8080AA"
                        android:textSize="22sp"
                        android:paddingStart="4dp"
                        android:paddingEnd="10dp"
                        android:layout_gravity="end|center_vertical" />

                </FrameLayout>

                <!-- Reps input -->
                <TextView
                    android:id="@+id/label_reps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Repeticiones"
                    android:textColor="#B0B0B0"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/input_reps"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/input_bg"
                    android:hint="0"
                    android:inputType="number"
                    android:textColor="@android:color/white"
                    android:textColorHint="#666666"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"
                    android:importantForAutofill="no" />

                <!-- Weight input -->
                <TextView
                    android:id="@+id/label_weight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Peso (kgs)"
                    android:textColor="#B0B0B0"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/input_weight"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/input_bg"
                    android:hint="0"
                    android:inputType="numberDecimal"
                    android:textColor="@android:color/white"
                    android:textColorHint="#666666"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"
                    android:importantForAutofill="no" />

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/btn_send"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Enviar"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#BB86FC"
                        android:layout_marginEnd="8dp" />

                    <ImageButton
                        android:id="@+id/btn_fullscreen"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/input_bg"
                        android:src="@drawable/ic_fullscreen"
                        android:contentDescription="Abrir app"
                        android:scaleType="centerInside" />

                </LinearLayout>

                <!-- Status text -->
                <TextView
                    android:id="@+id/txt_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <!-- Stats section (shown when expanded enough) -->
                <LinearLayout
                    android:id="@+id/stats_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#333344"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/txt_last_set"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#B0B0B0"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/txt_max_weight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#B0B0B0"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/txt_total_sets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#B0B0B0"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- Resize edges: transparent touch areas on all borders and corners -->
    <!-- Left edge -->
    <View
        android:id="@+id/resize_left"
        android:layout_width="12dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

    <!-- Right edge -->
    <View
        android:id="@+id/resize_right"
        android:layout_width="12dp"
        android:layout_height="match_parent"
        android:layout_gravity="end" />

    <!-- Bottom edge -->
    <View
        android:id="@+id/resize_bottom"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_gravity="bottom" />

    <!-- Top edge -->
    <View
        android:id="@+id/resize_top"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_gravity="top" />

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/expanded_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content card -->
    <LinearLayout
        android:id="@+id/content_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/expanded_bg"
        android:elevation="12dp"
        android:layout_margin="4dp"
        android:orientation="vertical">

        <!-- Drag handle -->
        <FrameLayout
            android:id="@+id/drag_handle"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="@android:color/transparent">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="@drawable/spinner_bg" />

        </FrameLayout>

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="4dp">

            <!-- Left: labels -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:letterSpacing="0.2"
                    android:text="CURRENT WORKOUT"
                    android:textAllCaps="true"
                    android:textColor="#C4C5D7"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/space_grotesk"
                    android:maxLines="1"
                    android:text="Entrenamiento"
                    android:textColor="#F4F2FF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Right: action buttons -->
            <ImageButton
                android:id="@+id/btn_minimize"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/panel_action_btn_bg"
                android:contentDescription="Minimizar"
                android:scaleType="centerInside"
                android:src="@android:drawable/arrow_down_float" />

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/panel_action_btn_bg"
                android:contentDescription="Cerrar"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_close_clear_cancel" />

        </LinearLayout>

        <!-- Timer -->
        <TextView
            android:id="@+id/txt_panel_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_grotesk"
            android:gravity="start"
            android:letterSpacing="-0.05"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp"
            android:text="00:00:00"
            android:textColor="#27E0A9"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Scrollable main content -->
        <ScrollView
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Exercise name -->
                <TextView
                    android:id="@+id/exercise_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/space_grotesk"
                    android:letterSpacing="-0.03"
                    android:maxLines="1"
                    android:text="–"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Set progress -->
                <TextView
                    android:id="@+id/txt_set_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/manrope"
                    android:text="Set 1 / –"
                    android:textColor="#27E0A9"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Input grid: Reps + Weight side by side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <!-- Reps stepper -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/stepper_container_bg"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/manrope"
                            android:letterSpacing="0.15"
                            android:text="REPS"
                            android:textAllCaps="true"
                            android:textColor="#C4C5D7"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:id="@+id/btn_reps_minus"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/stepper_btn_bg"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="−"
                                    android:textColor="#E4E1E9"
                                    android:textSize="18sp" />

                            </FrameLayout>

                            <TextView
                                android:id="@+id/txt_reps_value"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/space_grotesk"
                                android:gravity="center"
                                android:text="10"
                                android:textColor="@android:color/white"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <FrameLayout
                                android:id="@+id/btn_reps_plus"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/stepper_btn_bg"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="+"
                                    android:textColor="#E4E1E9"
                                    android:textSize="18sp" />

                            </FrameLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Weight stepper -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/stepper_container_bg"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/manrope"
                            android:letterSpacing="0.15"
                            android:text="WEIGHT (KG)"
                            android:textAllCaps="true"
                            android:textColor="#C4C5D7"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:id="@+id/btn_weight_minus"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/stepper_btn_bg"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="−"
                                    android:textColor="#E4E1E9"
                                    android:textSize="18sp" />

                            </FrameLayout>

                            <TextView
                                android:id="@+id/txt_weight_value"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/space_grotesk"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="@android:color/white"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <FrameLayout
                                android:id="@+id/btn_weight_plus"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/stepper_btn_bg"
                                android:clickable="true"
                                android:focusable="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="+"
                                    android:textColor="#E4E1E9"
                                    android:textSize="18sp" />

                            </FrameLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Log Set button -->
                <FrameLayout
                    android:id="@+id/btn_send"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/log_set_gradient_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/space_grotesk"
                        android:letterSpacing="0.15"
                        android:text="LOG SET"
                        android:textAllCaps="true"
                        android:textColor="#003827"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </FrameLayout>

                <!-- Exercise chips horizontal scroll -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/exercise_chips_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />

                </HorizontalScrollView>

                <!-- Status text -->
                <TextView
                    android:id="@+id/txt_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope"
                    android:textColor="#27E0A9"
                    android:textSize="12sp"
                    android:visibility="gone" />

            </LinearLayout>

        </ScrollView>

        <!-- Footer stats bar -->
        <LinearLayout
            android:id="@+id/stats_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_footer_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="10dp"
            android:paddingEnd="20dp"
            android:paddingBottom="10dp">

            <!-- Sets stat -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope"
                    android:letterSpacing="-0.03"
                    android:text="SETS"
                    android:textAllCaps="true"
                    android:textColor="#C4C5D7"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_stat_sets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="#1AFFFFFF" />

            <!-- Volume stat -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope"
                    android:letterSpacing="-0.03"
                    android:text="VOL"
                    android:textAllCaps="true"
                    android:textColor="#C4C5D7"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_stat_volume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="0 kg"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="#1AFFFFFF" />

            <!-- Time stat -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope"
                    android:letterSpacing="-0.03"
                    android:text="TIME"
                    android:textAllCaps="true"
                    android:textColor="#C4C5D7"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_stat_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/space_grotesk"
                    android:text="0m"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="#1AFFFFFF" />

            <!-- Fullscreen button -->
            <ImageButton
                android:id="@+id/btn_fullscreen"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/panel_action_btn_bg"
                android:contentDescription="Abrir app"
                android:scaleType="centerInside"
                android:src="@drawable/ic_fullscreen" />

        </LinearLayout>

    </LinearLayout>

    <!-- Resize edges -->
    <View
        android:id="@+id/resize_left"
        android:layout_width="12dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

    <View
        android:id="@+id/resize_right"
        android:layout_width="12dp"
        android:layout_height="match_parent"
        android:layout_gravity="end" />

    <View
        android:id="@+id/resize_bottom"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_gravity="bottom" />

    <View
        android:id="@+id/resize_top"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_gravity="top" />

</FrameLayout>

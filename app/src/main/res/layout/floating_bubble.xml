<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bubble_root"
    android:layout_width="64dp"
    android:layout_height="72dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Main bubble circle -->
    <FrameLayout
        android:id="@+id/bubble_circle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="top|center_horizontal"
        android:background="@drawable/bubble_bg">

        <!-- Fitness center icon -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_fitness"
            android:contentDescription="Entrenamiento activo"
            android:scaleType="fitCenter" />

    </FrameLayout>

    <!-- Timer badge overlaid at bottom -->
    <TextView
        android:id="@+id/txt_bubble_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:background="@drawable/bubble_pill_bg"
        android:fontFamily="@font/space_grotesk"
        android:gravity="center"
        android:includeFontPadding="false"
        android:minWidth="44dp"
        android:paddingStart="8dp"
        android:paddingTop="2dp"
        android:paddingEnd="8dp"
        android:paddingBottom="2dp"
        android:text="0:00"
        android:textColor="#003827"
        android:textSize="9sp"
        android:textStyle="bold" />

</FrameLayout>
